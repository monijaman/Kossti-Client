# Local Development Environment - Copy to .env and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:9090
NEXTAUTH_SECRET=secret
NEXTAUTH_URL=http://localhost:3000

# Application Port
PORT=3000

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Kossti

# Reddit (from reddit.com/prefs/apps)
NEXT_PUBLIC_REDDIT_CLIENT_ID=your_id
NEXT_PUBLIC_REDDIT_CLIENT_SECRET=your_secret

# Facebook (from developers.facebook.com)
NEXT_PUBLIC_FACEBOOK_ACCESS_TOKEN=your_token

# Amazon Reviews (from rainforest.ai)
NEXT_PUBLIC_AMAZON_API_KEY=your_key

# OpenAI API Key (from https://platform.openai.com/api-keys)
NEXT_PUBLIC_OPENAI_API_KEY=your_openai_key_here

# ============================================
# PRODUCTION (Railway) Environment Variables
# ============================================
# Copy these examples to Railway dashboard environment variables:
# NEXT_PUBLIC_API_URL=https://gocritserver-production.up.railway.app
# NEXTAUTH_URL=https://kossti.com
# NEXT_PUBLIC_SITE_URL=https://kossti.com
# NEXTAUTH_SECRET=<generate-random-secret>
# NEXT_PUBLIC_OPENAI_API_KEY=<your-production-key>
